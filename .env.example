# ─── Ultraviolet environment configuration ───
# Copy this file to `.env` and adjust values as needed.

# ── Backend / Database ──
DATABASE_URL=postgresql://ultraviolet:ultraviolet@postgres:5432/ultraviolet

# ── ChromaDB (vector store) ──
# Inside the Docker network ChromaDB listens on port 8000.
# It is published to the host on 8001 (see docker-compose.yml).
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000

# ── Ollama (local LLM runtime) ──
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=goekdenizguelmez/JOSIEFIED-Qwen3:8b
EMBEDDING_MODEL=nomic-embed-text

# ── CORS: comma-separated list of allowed frontend origins ──
CORS_ORIGINS=http://localhost:3000

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:8000
