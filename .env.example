# Ultraviolet — local dev on D: drive (no Docker required for Analyze/DJ)

# ── All heavy downloads go to D:, NOT C: ──
STEM_CACHE_DIR=D:/ultraviolet-data/stems
CATALOG_DIR=D:/ultraviolet-data/catalog
SESSION_DIR=D:/ultraviolet-data/sessions
TORCH_HOME=D:/ultraviolet-data/torch
XDG_CACHE_HOME=D:/ultraviolet-data/cache
HF_HOME=D:/ultraviolet-data/huggingface

# ── Demucs ──
# RTX 50-series (sm_120) needs PyTorch 2.7+ built with CUDA 12.8 (cu128 wheel).
# If analyze fails with "no kernel image", run scripts/upgrade-pytorch-cu128.ps1
DEMUCS_MODEL=htdemucs
DEMUCS_DEVICE=cuda

# ── Ollama (optional — Chat/SOUL only; unload before Demucs runs automatically) ──
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=goekdenizguelmez/JOSIEFIED-Qwen3:8b

# ── NicheSearch (Spotify + YouTube + SoundCloud) ──
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── API ──
CORS_ORIGINS=http://localhost:3000
