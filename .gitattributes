# Normalize line endings to LF in the repo (CI + Docker run on Linux).
* text=auto eol=lf
# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
frontend/public/data/*.bin filter=lfs diff=lfs merge=lfs -text
backend/data/static/*.npz filter=lfs diff=lfs merge=lfs -text
